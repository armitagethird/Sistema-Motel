# Supabase (frontend — seguro expor como VITE_*)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Stone / Pagar.me — apenas processo Rust, NUNCA como VITE_*
# Definir como variável de ambiente do sistema operacional antes de rodar tauri:
#   Windows:  set STONE_SECRET_KEY=sk_...
#   PowerShell: $env:STONE_SECRET_KEY = "sk_..."
STONE_SECRET_KEY=
STONE_ACCOUNT_ID=

# Evolution API (WhatsApp) — lida pelo Rust via invoke
EVOLUTION_API_URL=https://...
EVOLUTION_API_KEY=...
EVOLUTION_INSTANCE=...
